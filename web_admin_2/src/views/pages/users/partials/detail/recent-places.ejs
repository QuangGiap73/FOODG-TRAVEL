<section class="user-detail-card user-places-card">
  <div class="user-section-head">
    <h3>Quan da ghe gan day</h3>
    <a href="#">Xem tat ca</a>
  </div>

  <% if (user.recentPlaces.length) { %>
    <div class="user-place-list">
      <% user.recentPlaces.forEach(function (item) { %>
        <article class="user-place-item">
          <img src="<%= item.image %>" alt="<%= item.title %>" />
          <div class="user-place-item__body">
            <strong><%= item.title %></strong>
            <span><%= item.subtitle %></span>
            <small>⭐ <%= item.rating.toFixed(1) %></small>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="user-empty-state">Chua co dia diem gan day.</div>
  <% } %>
</section>
