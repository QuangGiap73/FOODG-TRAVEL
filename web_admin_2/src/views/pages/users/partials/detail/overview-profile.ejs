<section class="user-detail-card user-overview-card">
  <div class="user-section-head">
    <h3>Hồ sơ cá nhân</h3>
  </div>

  <div class="user-overview-list">
    <% user.overviewProfile.forEach(function (item) { %>
      <div class="user-overview-list__row">
        <span><%= item.label %></span>
        <strong><%= item.value %></strong>
      </div>
    <% }) %>
  </div>
</section>
