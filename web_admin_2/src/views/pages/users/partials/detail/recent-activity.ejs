<section class="user-detail-card user-activity-card">
  <div class="user-section-head">
    <h3>Hoạt động gần đây</h3>
    <a href="#">Xem tất cả</a>
  </div>

  <% if (user.recentActivity.length) { %>
    <div class="user-activity-list">
      <% user.recentActivity.forEach(function (item) { %>
        <div class="user-activity-item">
          <div class="user-activity-item__dot user-activity-item__dot--<%= item.colorClass %>"><%= item.icon %></div>
          <div class="user-activity-item__body">
            <strong><%= item.title %></strong>
            <span><%= item.subtitle %></span>
          </div>
          <small><%= item.time %></small>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="user-empty-state">Chưa có hoạt động gần đây.</div>
  <% } %>
</section>
