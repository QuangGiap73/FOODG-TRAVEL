<%- include('../../partials/page-header', {
  eyebrow: 'Tong quan',
  title: 'Dashboard',
  description: 'Khung dashboard moi de migrate dan toan bo admin cu sang cau truc module.',
}) %>

<section class="stats-grid">
  <% overview.stats.forEach(function (item) { %>
    <article class="stat-card">
      <p><%= item.label %></p>
      <h3><%= item.value %></h3>
      <span><%= item.hint %></span>
    </article>
  <% }) %>
</section>

<section class="panel-grid">
  <article class="panel-card">
    <div class="panel-card__header">
      <h3>Huong migrate</h3>
    </div>
    <ul class="task-list">
      <% overview.tasks.forEach(function (task) { %>
        <li><%= task %></li>
      <% }) %>
    </ul>
  </article>

  <article class="panel-card panel-card--accent">
    <div class="panel-card__header">
      <h3>Nguyen tac kien truc</h3>
    </div>
    <ul class="task-list">
      <li>Route mo ta endpoint, khong chua nghiep vu.</li>
      <li>Controller mong, service xu ly logic.</li>
      <li>Repository lam viec voi Firestore va upload.</li>
      <li>View va JS duoc tach thanh primitive dung lai.</li>
    </ul>
  </article>
</section>
